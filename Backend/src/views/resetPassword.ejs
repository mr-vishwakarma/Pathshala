<!DOCTYPE html>
<html>
<head>
  <title>Reset Password</title>
</head>

<body>

  <h1>Reset Password</h1>

  <form
    method="POST"
    action="/api/auth/reset-password/<%=token%>"
  >

    <input
      type="password"
      name="password"
      placeholder="Enter new password"
      required
    />

    <button type="submit">
      Reset Password
    </button>

  </form>

</body>
</html>